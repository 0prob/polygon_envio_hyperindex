# ==============================================================================
# Polygon (137) DEX Pool Discovery Indexer — Environment
# ==============================================================================
# Copy to .env and fill in values before running.
# See README.md for full variable descriptions.
# `bun run dev` bridges POLYGON_START_BLOCK → ENVIO_POLYGON_START_BLOCK and
# POLYGON_RPC_URLS → ENVIO_POLYGON_RPC_URLS automatically.

# ==============================================================================
# REQUIRED
# ==============================================================================

# Envio API token for HyperSync (production use).
ENVIO_API_TOKEN=your_envio_api_token_here

# Comma-separated archival RPC endpoints for metadata effects
# (token decimals, Curve/Balancer/DODO/WooFi metadata reads).
# rpc_client.ts reads ENVIO_POLYGON_RPC_URLS → ENVIO_POLYGON_RPC_URL → POLYGON_RPC_URLS → POLYGON_RPC_URL → POLYGON_RPC
# in that order. First healthy endpoint becomes primary; others are fallback.
# Public fallbacks are appended automatically when < 3 endpoints are configured.
ENVIO_POLYGON_RPC_URLS=https://your-archival-rpc.example.com

# ==============================================================================
# HYPER SYNC
# ==============================================================================

# HyperSync endpoint override (default: https://polygon.hypersync.xyz)
# ENVIO_POLYGON_HYPERSYNC_URL=https://polygon.hypersync.xyz

# Blocks per HyperSync request (default: 6000, set via config.yaml interpolation)
# ENVIO_FULL_BATCH_SIZE=6000

# Max HyperSync requests per minute for pacing (default: 180)
# ENVIO_HYPERSYNC_RPM_TARGET=180

# ==============================================================================
# START BLOCK (partial re-sync / live-tail mode)
# ==============================================================================

# Override start block for all contracts.
# Set to a recent block (e.g. 86000000) for fast tail — no historical backfill.
# ENVIO_POLYGON_START_BLOCK=4931780

# ==============================================================================
# INDEXER PROGRESS (stride tuning)
# ==============================================================================

# Block to switch from historical → realtime stride (default: 65000000)
# INDEXER_PROGRESS_REALTIME_START=65000000

# Blocks per progress update during historical sync (default: 4000)
# INDEXER_PROGRESS_HISTORICAL_EVERY=4000

# Blocks per progress update during realtime sync (default: 500)
# INDEXER_PROGRESS_REALTIME_EVERY=500

# ==============================================================================
# OPTIONAL PATHS
# ==============================================================================

# Override token registry SQLite path (default: data/token_registry.db)
# TOKEN_REGISTRY_DB=data/token_registry.db

# Override pools.json path (default: data/pools.json)
# POOLS_JSON=data/pools.json

# ==============================================================================
# LOGGING
# ==============================================================================

# Envio log level: info | debug | trace | warn | error
# ENVIO_LOG_LEVEL=info
