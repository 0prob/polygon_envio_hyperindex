# Envio v3 Environment Variables
# RPC/HyperSync variables use ENVIO_ prefix per Envio convention.
# `bun run dev` bridges root aliases (POLYGON_START_BLOCK, HYPER_SYNC_URL, POLYGON_RPC_URLS)
# to ENVIO_* keys via scripts/envio-dev.ts (same as the arb bot's buildHyperIndexChildEnv).

# ==============================================================================
# REQUIRED
# ==============================================================================

# Envio API token for HyperSync (production).
ENVIO_API_TOKEN=your_envio_api_token_here

# Comma-separated archival RPC endpoints for metadata effects
# (token decimals, Curve/Balancer/DODO metadata reads).
# First healthy endpoint becomes primary; others are fallback.
ENVIO_POLYGON_RPC_URLS=https://your-rpc-endpoint.example,https://polygon-rpc.com

# ==============================================================================
# PERFORMANCE TUNING (see src/utils/pacing.ts)
# ==============================================================================

# HYPERSYNC_RPM_TARGET:
#   Controls effect concurrency (metadata lookups), batch size, and onBlock stride selection.
#   - Code default: 180 (rpmFromEnv fallback)
#   - Paid plan (~200 rpm): set to 200
#   - Free tier: 100-150
#   Lower this if encountering "Rate limit exceeded" backoffs.
#   Legacy alias (third fallback): HYPERSYNC_MAX_RPM_PER_TOKEN
ENVIO_HYPERSYNC_RPM_TARGET=200

# FULL_BATCH_SIZE:
#   Blocks per HyperSync request. Auto-tuned from RPM target if unset
#   (see getRecommendedFullBatchSizeForRpm in src/utils/pacing.ts).
#   Bigger batches amortize roundtrips; smaller batches reduce spike size.
#   Paid Starter (rpm >= 180): auto (6000) | Free Tier: auto (1000-2800)
# ENVIO_FULL_BATCH_SIZE=6000

# ==============================================================================
# START BLOCK OVERRIDE (partial re-sync / live-debug mode)
# ==============================================================================

# Override start block for all contracts.
# Set to a recent block (e.g. 86000000) for fast tail — no historical backfill.
# The bot process manager sets POLYGON_START_BLOCK; pacing.ts bridges both names.
# ENVIO_POLYGON_START_BLOCK=4931780
# POLYGON_START_BLOCK=86000000

# ==============================================================================
# INDEXER PROGRESS (src/handlers/progress.ts)
# ==============================================================================

# Block at which the progress handler switches from coarse historical stride
# (every 4000 blocks) to fine realtime stride (every 500 blocks).
# Default: 65,000,000. Auto-set to chainStart when >= 80M (live-debug mode).
# INDEXER_PROGRESS_REALTIME_START=65000000

# Stride intervals (override defaults):
# INDEXER_PROGRESS_HISTORICAL_EVERY=4000
# INDEXER_PROGRESS_REALTIME_EVERY=500

# ==============================================================================
# HYPER SYNC
# ==============================================================================

# Override the HyperSync endpoint (default: https://polygon.hypersync.xyz).
# ENVIO_POLYGON_HYPERSYNC_URL=https://polygon.hypersync.xyz
# HYPER_SYNC_URL=https://polygon.hypersync.xyz    # alias bridged by pacing.ts

# ==============================================================================
# OPTIONAL PATHS
# ==============================================================================

# Override token registry SQLite path (default: data/token_registry.db).
# TOKEN_REGISTRY_DB=/path/to/token_registry.db

# ==============================================================================
# TESTING
# ==============================================================================

# Vitest sets VITEST=true automatically.
# Set NODE_ENV=test to disable Envio effect caching (re-runs RPC on every call).
# NODE_ENV=test

# ==============================================================================
# LOGGING
# ==============================================================================

ENVIO_LOG_LEVEL=info
