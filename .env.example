# Envio v3 Compliant Environment Variables
# All variables MUST use ENVIO_ prefix per Envio documentation

# Core Envio Configuration (REQUIRED)
ENVIO_API_TOKEN=your_envio_api_token_here

# RPC Configuration (REQUIRED)
ENVIO_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ENVIO_POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com

# Hasura Configuration
ENVIO_HASURA_ADMIN_SECRET=testing
ENVIO_HASURA_SECRET=testing

# ==============================================================================
# PERFORMANCE TUNING (See hyperindex/src/utils/pacing.ts)
# ==============================================================================

# HYPERSYNC_RPM_TARGET:
#   Controls effect concurrency (batching of token metadata lookups) and onBlock frequency.
#   - Paid Starter Plan (~200 rpm): 200 (Default)
#   - Free Tier: 100-150
#   Lower this if encountering "Rate limit exceeded" server backoffs.
ENVIO_HYPERSYNC_RPM_TARGET=200

# FULL_BATCH_SIZE:
#   Controls how many blocks HyperSync fetches in one request.
#   Amortizes overhead but creates larger, spikier request patterns.
#   - Paid Starter Plan: 4500
#   - Free Tier: 1000-1800
ENVIO_FULL_BATCH_SIZE=4500

# OPTIONAL:
# Override start block for historical backfill (e.g. recent block for fast tail)
# ENVIO_POLYGON_START_BLOCK=5024576

# INDEXER_HOT_BIAS (optional, not recommended for long-tail routing):
# When enabled, restricts pool discovery toward high-liquidity / major-token pairs.
# Leave unset for broad long-tail discovery (default bot strategy: ROUTING_STRATEGY=long-tail).
# Only enable when intentionally running hot-path mode (ROUTING_STRATEGY=balanced).
# INDEXER_HOT_BIAS=true

# ==============================================================================

# Other
ENVIO_LOG_LEVEL=info
ENVIO_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HERE
ENVIO_CHAINSTACK_RPS=250
# Effects use ENVIO_POLYGON_RPC_URLS.
