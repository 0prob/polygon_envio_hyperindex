{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["es2022"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "envio-env.d.ts", "env.d.ts"]
}
