{
  "name": "arb-bot-ingestion",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "envio codegen",
    "dev": "bun scripts/envio-dev.ts",
    "run": "bun scripts/envio-dev.ts run",
    "validate-config": "python3 scripts/validate_envio_config.py",
    "validate-data": "python3 scripts/validate_data.py",
    "validate": "bun run validate-config && bun run validate-data",
    "generate-tokens": "bun scripts/generate-polygon-tokens.ts",
    "backup-db": "bash scripts/backup-db.sh",
    "migrate-db": "bash scripts/migrate-db.sh",
    "repair-balancer-pooltype": "bun scripts/repair-balancer-pooltype.ts"
  },
  "dependencies": {
    "envio": "3.2.1",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
